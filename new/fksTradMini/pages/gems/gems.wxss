.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #eef2ff 0%, #f6f8ff 20%, #f5f6fa 100%);
}

.hero-card,
.section-card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(82, 104, 184, 0.08);
}

.hero-card {
  padding: 30rpx 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #18224f 0%, #3b4fd5 56%, #47c9ff 100%);
}

.hero-copy { flex: 1; min-width: 0; }
.hero-kicker,
.section-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
}
.hero-kicker { color: rgba(255, 255, 255, 0.68); }
.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #ffffff;
}
.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.82);
}
.hero-balance-card {
  flex-shrink: 0;
  min-width: 188rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.14);
  border: 1rpx solid rgba(255,255,255,0.16);
}
.hero-balance-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}
.hero-balance-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}
.hero-gem { width: 34rpx; height: 34rpx; }
.hero-balance-num {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #ffffff;
}

.stats-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}
.stat-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(82, 104, 184, 0.06);
}
.stat-label {
  display: block;
  font-size: 22rpx;
  color: #8a92a8;
}
.stat-value {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 800;
  color: #1d2640;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
}
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 18rpx;
  margin-bottom: 20rpx;
}
.section-kicker { color: #9aa3bf; }
.section-title {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #1b2340;
}
.section-link {
  font-size: 22rpx;
  color: #4f63db;
  font-weight: 700;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
.action-card {
  min-height: 204rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}
.action-card-primary {
  background: linear-gradient(135deg, #18224f 0%, #4f46e5 60%, #60a5fa 100%);
}
.action-card-warm {
  background: linear-gradient(135deg, #fff7ed 0%, #ffe8cd 100%);
}
.action-icon {
  font-size: 40rpx;
  line-height: 1;
  color: inherit;
}
.action-title {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}
.action-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
}
.action-card-primary .action-title,
.action-card-primary .action-desc,
.action-card-primary .action-icon {
  color: #ffffff;
}
.action-card-warm .action-title {
  color: #7c2d12;
}
.action-card-warm .action-desc,
.action-card-warm .action-icon {
  color: #9a3412;
}

.bind-tip-card {
  margin-top: 18rpx;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  background: linear-gradient(135deg, #fff7ed, #fff1db);
  border: 1rpx solid #fde3bc;
}
.bind-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #9a3412;
}
.bind-tip-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9f5b26;
}
.bind-tip-btn {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #d97706;
  font-size: 22rpx;
  font-weight: 700;
}

.pending-card {
  margin-top: 18rpx;
  border-radius: 24rpx;
  padding: 22rpx;
  background: #f8faff;
  border: 1rpx solid #e8edff;
}
.pending-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}
.pending-kicker {
  display: block;
  font-size: 22rpx;
  color: #8b95b2;
}
.pending-id {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #334155;
  word-break: break-all;
}
.pending-status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
  font-weight: 700;
}
.pending-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}
.pending-metric {
  border-radius: 18rpx;
  background: #ffffff;
  padding: 18rpx 16rpx;
}
.pending-metric-label {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
}
.pending-metric-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2937;
}
.pending-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

.record-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #F1F4F8;
}
.record-item:last-child { border-bottom: none; }
.record-left { flex: 1; min-width: 0; }
.record-desc {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.5;
}
.record-time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}
.record-amount {
  font-size: 34rpx;
  font-weight: 800;
}
.income { color: #16A34A; }
.spend { color: #EF4444; }
.empty-view { padding: 50rpx 24rpx; text-align: center; }
.empty-text { font-size: 26rpx; color: #B0B7C7; }

.transfer-history-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}
.history-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #F1F4F8;
}
.history-item:last-child { border-bottom: none; }
.history-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 16rpx;
}
.history-id {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}
.history-time {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #cbd5e1;
}
.history-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}
.history-status-pending {
  background: #eef2ff;
  color: #4f46e5;
}
.history-status-done {
  background: #dcfce7;
  color: #16a34a;
}
.history-status-cancelled {
  background: #f1f5f9;
  color: #64748b;
}
.history-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}
.history-metric {
  border-radius: 16rpx;
  background: #f8fafc;
  padding: 14rpx 12rpx;
}
.history-metric-label {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
}
.history-metric-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #1e293b;
}
.history-note {
  display: block;
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}
