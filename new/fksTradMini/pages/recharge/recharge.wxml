<!-- 转入宝石 -->
<view class="container">
  <view class="balance-bar">
    <view>
      <text class="bal-label">当前宝石余额</text>
      <view class="bal-row">
        <image class="bal-gem" src="/assets/baoshi.png" mode="aspectFit"/>
        <text class="bal-num">{{gemBalance}}</text>
      </view>
    </view>
    <view class="limit-box">
      <text class="limit-num">取消 {{cancelCount}} / {{cancelLimit}}</text>
      <text class="limit-tip">超出后将限制转入</text>
    </view>
  </view>

  <view class="panel-card">
    <view class="panel-head">
      <view class="panel-title-row">
        <text class="panel-title">转入宝石</text>
        <text class="panel-link" bindtap="showTutorial">查看教程</text>
      </view>
      <text class="panel-sub">{{verifyModeText}}，订单校验直接读取真实交易日志时间的后 4 位数字</text>
    </view>

    <view class="stepper-row">
      <view class="stepper-item">
        <view class="stepper-circle {{currentStep >= 1 ? 'stepper-active' : ''}}">1</view>
        <text class="stepper-text {{currentStep >= 1 ? 'stepper-text-active' : ''}}">创建订单</text>
      </view>
      <view class="stepper-line {{currentStep >= 2 ? 'stepper-line-active' : ''}}"></view>
      <view class="stepper-item">
        <view class="stepper-circle {{currentStep >= 2 ? 'stepper-active' : ''}}">2</view>
        <text class="stepper-text {{currentStep >= 2 ? 'stepper-text-active' : ''}}">购买沙粒</text>
      </view>
      <view class="stepper-line {{currentStep >= 3 ? 'stepper-line-active' : ''}}"></view>
      <view class="stepper-item">
        <view class="stepper-circle {{currentStep >= 3 ? 'stepper-active' : ''}}">3</view>
        <text class="stepper-text {{currentStep >= 3 ? 'stepper-text-active' : ''}}">完成</text>
      </view>
    </view>

    <block wx:if="{{currentStep === 1}}">
      <view class="form-title-row">
        <text class="form-title">创建转入订单</text>
        <text class="form-tag">10分钟有效</text>
      </view>

      <view class="form-item">
        <view class="form-label required">转入宝石数量</view>
        <view class="input-with-unit">
          <input
            class="form-input"
            type="number"
            placeholder="请输入转入数量"
            value="{{rechargeAmount}}"
            bindinput="onAmountInput"
            placeholder-style="color:#bbb"
          />
          <image class="unit-gem" src="/assets/baoshi.png" mode="aspectFit"/>
        </view>
      </view>

      <view class="amount-tips">
        <view
          class="amount-tip-item"
          wx:for="{{quickAmounts}}"
          wx:key="*this"
          bindtap="setQuickAmount"
          data-val="{{item}}"
        >{{item}}</view>
      </view>

      <view class="biz-card">
        <view class="biz-row">
          <text class="biz-key">收款方块兽ID</text>
          <text class="biz-val">{{appBeastId}}</text>
        </view>
        <view class="biz-row">
          <text class="biz-key">收款昵称</text>
          <text class="biz-val">{{appBeastNick}}</text>
        </view>
        <view class="biz-row biz-row-last">
          <text class="biz-key">业务规则</text>
          <text class="biz-val biz-val-light">一个账号最多取消 5 次，超过后无法继续转入</text>
        </view>
      </view>

      <view class="submit-btn {{cancelCount >= cancelLimit ? 'btn-gray' : 'btn-primary'}}" bindtap="createRechargeOrder">创建转入订单</view>
    </block>

    <block wx:elif="{{currentStep === 2 && currentOrder}}">
      <view class="countdown-wrap">
        <text class="countdown-text">{{countdownText}}</text>
        <text class="countdown-tip">请 {{orderExpireMinutes}} 分钟内完成购买沙粒并验证</text>
      </view>

      <view class="order-card">
        <view class="order-top-row">
          <text class="order-label">转入单号</text>
          <view class="copy-btn-sm" bindtap="copyOrderId">复制单号</view>
        </view>
        <text class="order-id">{{rechargeOrderId}}</text>
        <view class="order-info-grid">
          <view class="info-cell">
            <text class="info-cell-label">方块兽ID</text>
            <view class="info-cell-val-row">
              <text class="info-cell-val info-id">{{appBeastId}}</text>
              <view class="copy-btn-inline" bindtap="copyBeastId">复制</view>
            </view>
          </view>
          <view class="info-cell">
            <text class="info-cell-label">方块兽昵称</text>
            <text class="info-cell-val">{{appBeastNick}}</text>
          </view>
          <view class="info-cell">
            <text class="info-cell-label">购买沙粒</text>
            <view class="info-cell-gem-row">
              <image class="gem-inline" src="/assets/baoshi.png" mode="aspectFit"/>
              <text class="info-cell-val">{{rechargeAmount}}</text>
            </view>
          </view>
          <view class="info-cell">
            <text class="info-cell-label">下单时间</text>
            <text class="info-cell-val">{{createdTimeText}}</text>
          </view>
        </view>
      </view>

      <view class="verify-card">
        <view class="verify-title-row">
          <text class="verify-title">输入交易时间后4位数字</text>
          <text class="verify-help">如 17:16:18 → 1618</text>
        </view>
        <text class="verify-smart-tip">支持直接粘贴完整时间（如 17:16:18），系统自动提取后4位</text>
        <input
          class="verify-input"
          maxlength="10"
          placeholder="输入4位数字或粘贴完整时间"
          value="{{verifyCode}}"
          bindinput="onVerifyInput"
          placeholder-style="color:#bbb;text-align:center"
        />
        <view class="submit-btn {{verifyCode.length === 4 ? 'btn-primary' : 'btn-gray'}}" bindtap="verifyOrder">验证订单</view>
      </view>

      <view class="cancel-btn" bindtap="cancelRechargeOrder">取消订单</view>
      <text class="cancel-tip">剩余可取消 {{cancelRemain}} 次，超限后不可继续发起转入</text>
    </block>

    <block wx:elif="{{currentStep === 3}}">
      <view class="success-card">
        <text class="success-icon">✅</text>
        <text class="success-title">转入成功</text>
        <view class="success-amount-row">
          <image class="gem-inline success-gem" src="/assets/baoshi.png" mode="aspectFit"/>
          <text class="success-amount">{{rechargeAmount}}</text>
          <text class="success-amount-unit">宝石已到账</text>
        </view>
        <text class="success-desc">已匹配交易时间：{{matchedLogTime}}</text>
        <view class="success-balance">当前余额：{{gemBalance}} 宝石</view>
        <view class="btn-primary success-btn" bindtap="resetRecharge">继续转入</view>
        <view class="btn-outline success-btn2" bindtap="goGuarantee">去生成担保单</view>
      </view>
    </block>
  </view>

  <view class="record-section">
    <view class="section-title-bar">
      <text class="sec-title">转入记录</text>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{rechargeHistory}}" wx:key="id">
        <view class="record-left">
          <text class="record-order-id">{{item.id}}</text>
          <text class="record-desc">{{item.desc}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        <view class="record-right">
          <view class="record-amount-row">
            <image class="gem-inline" src="/assets/baoshi.png" mode="aspectFit"/>
            <text class="record-amount amount-{{item.statusClass}}">{{item.amountPrefix}}{{item.amount}}</text>
          </view>
          <view class="record-status record-status-{{item.statusClass}}">{{item.statusText}}</view>
        </view>
      </view>
      <view class="empty-view" wx:if="{{rechargeHistory.length === 0}}">
        <text class="empty-text">暂无转入记录</text>
      </view>
    </view>
  </view>
</view>
