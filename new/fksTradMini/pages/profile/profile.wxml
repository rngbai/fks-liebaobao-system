<!-- 个人设置 -->
<view class="container">

  <!-- 头像 -->
  <view class="avatar-section">
    <button class="avatar-wrap avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="big-avatar" src="{{form.avatarUrl || '/assets/default_avatar.png'}}" mode="aspectFill"/>
      <view class="avatar-edit">使用微信头像</view>
    </button>
    <text class="avatar-tip">点击头像可直接选择微信头像，保存后会同步到个人资料。</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="fi-label">昵称</text>
      <input class="fi-input" type="nickname" placeholder="请输入昵称" value="{{form.nickName}}" bindinput="onInput" data-field="nickName" placeholder-style="color:#bbb"/>
    </view>
    <view class="form-item">
      <text class="fi-label">账号（选填）</text>
      <input class="fi-input" placeholder="仅用于后台识别，不会当昵称显示" value="{{form.account}}" bindinput="onInput" data-field="account" placeholder-style="color:#bbb"/>
    </view>

    <view class="form-item">
      <text class="fi-label">手机号</text>
      <input class="fi-input" type="number" placeholder="请绑定手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" placeholder-style="color:#bbb"/>
    </view>
    <view class="form-item">
      <text class="fi-label">电子邮箱</text>
      <input class="fi-input" placeholder="请绑定邮箱" value="{{form.email}}" bindinput="onInput" data-field="email" placeholder-style="color:#bbb"/>
    </view>
    <view class="form-item">
      <text class="fi-label">方块兽ID</text>
      <input class="fi-input" placeholder="请绑定游戏ID" value="{{form.beastId}}" bindinput="onInput" data-field="beastId" placeholder-style="color:#bbb"/>
    </view>
  </view>

  <text class="form-note">微信头像和昵称在这里单独设置，账号字段只是补充信息，不会默认覆盖昵称展示。</text>

  <view class="form-card">
    <view class="form-item no-border" bindtap="changePassword">

      <text class="fi-label">修改密码</text>
      <text class="fi-arrow">›</text>
    </view>
  </view>

  <view class="submit-wrap">
    <view class="btn-primary save-btn" bindtap="saveProfile">保存修改</view>
  </view>

</view>
