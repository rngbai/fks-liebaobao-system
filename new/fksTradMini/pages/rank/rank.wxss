.page {
  min-height: 100vh;
  padding: 26rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #0d1630 0%, #18295d 18%, #f4f6ff 18%, #eef2ff 100%);
}

.hero-card,
.podium-card,
.list-card,
.group-cta {
  border-radius: 28rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 14rpx 34rpx rgba(60, 83, 152, 0.12);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #1a1e48, #4f46e5 56%, #22d3ee 100%);
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.68);
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255,255,255,0.82);
}

.tab-row {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.tab-chip {
  flex: 1;
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid #dfe7ff;
}

.tab-chip-active {
  background: linear-gradient(135deg, #1a275c, #4e5ff1);
  border-color: transparent;
  box-shadow: 0 12rpx 24rpx rgba(76, 93, 214, 0.24);
}

.tab-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #18213a;
}

.tab-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #7a849f;
}

.tab-chip-active .tab-title,
.tab-chip-active .tab-desc {
  color: #ffffff;
}

.podium-card,
.list-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #14203d;
}

.podium-row {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.podium-item {
  flex: 1;
  min-height: 220rpx;
  padding: 24rpx 18rpx;
  border-radius: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.podium-item-1 {
  background: linear-gradient(180deg, #ffefae, #f6b442);
}

.podium-item-2 {
  background: linear-gradient(180deg, #eef2ff, #c0c7dc);
}

.podium-item-3 {
  background: linear-gradient(180deg, #ffd8bd, #f1a46d);
}

.podium-rank {
  font-size: 40rpx;
}

.podium-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1c2340;
}

.podium-score,
.podium-reward {
  display: block;
  font-size: 21rpx;
  line-height: 1.5;
  color: #3f4867;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1fb;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-no {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #eff3ff;
  color: #3550cf;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.rank-main {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #18213a;
}

.rank-slogan {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.58;
  color: #7a839a;
}

.rank-side {
  text-align: right;
}

.rank-score,
.rank-reward {
  display: block;
}

.rank-score {
  font-size: 24rpx;
  font-weight: 700;
  color: #3347c2;
}

.rank-reward {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9aa2b7;
}

.group-cta {
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #171f47, #3555de 56%, #2dd4bf 100%);
}

.group-cta-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.group-cta-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255,255,255,0.76);
}

.group-cta-arrow {
  font-size: 54rpx;
  color: rgba(255,255,255,0.9);
}
