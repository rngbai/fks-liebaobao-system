.container { background: #F5F6FA; min-height: 100vh; padding-bottom: 60rpx; }

.type-banner { padding: 28rpx 32rpx; }
.sell-banner { background: linear-gradient(135deg, #5B6EF5, #8B5CF6); }
.buy-banner { background: linear-gradient(135deg, #10B981, #059669); }
.type-banner-text { font-size: 32rpx; font-weight: 800; color: #fff; }

.detail-card { background: #fff; margin: 20rpx 24rpx 0; border-radius: 20rpx; padding: 28rpx 24rpx; }
.detail-title-text { font-size: 34rpx; font-weight: 800; color: #222; margin-bottom: 24rpx; }
.detail-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.detail-row:last-child { border-bottom: none; }
.dk { font-size: 24rpx; color: #999; flex-shrink: 0; margin-right: 20rpx; }
.dv { font-size: 26rpx; color: #333; font-weight: 500; text-align: right; flex: 1; }
.price-val { color: #8B5CF6; font-weight: 800; }
.total-price { color: #EF4444; font-weight: 800; }
.desc-val { color: #555; }

.contact-card { background: #fff; margin: 20rpx 24rpx 0; border-radius: 20rpx; padding: 28rpx 24rpx; }
.contact-title { font-size: 28rpx; font-weight: 700; color: #222; margin-bottom: 8rpx; }
.contact-tip { font-size: 22rpx; color: #bbb; margin-bottom: 24rpx; line-height: 1.5; }
.contact-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.contact-row:last-child { border-bottom: none; }
.contact-icon-wrap { width: 72rpx; height: 72rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.qq-bg { background: #1677FF; }
.wx-bg { background: #07C160; }
.contact-icon { font-size: 24rpx; font-weight: 800; color: #fff; }
.contact-info { flex: 1; }
.contact-label { display: block; font-size: 20rpx; color: #bbb; margin-bottom: 4rpx; }
.contact-val { font-size: 28rpx; font-weight: 700; color: #222; }
.copy-contact-btn { background: linear-gradient(135deg,#5B6EF5,#8B5CF6); color: #fff; border-radius: 12rpx; padding: 10rpx 24rpx; font-size: 24rpx; font-weight: 600; }

.guarantee-tip-card { background: #FFF9E6; margin: 20rpx 24rpx 0; border-radius: 20rpx; padding: 28rpx 24rpx; border: 1rpx solid #FFE58F; }
.gtip-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.gtip-icon { font-size: 36rpx; }
.gtip-title { font-size: 28rpx; font-weight: 700; color: #D97706; }
.gtip-content { font-size: 24rpx; color: #888; line-height: 1.7; margin-bottom: 24rpx; }
.gtip-btn { padding: 0; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; text-align: center; }
