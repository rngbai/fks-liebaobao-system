.container { background: #F5F6FA; min-height: 100vh; padding-bottom: 60rpx; }

.user-header {
  background: linear-gradient(135deg, #5B6EF5, #8B5CF6);
  padding: 60rpx 32rpx 44rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-wrap,
.user-avatar-wrap { position: relative; flex-shrink: 0; }
.avatar { width: 128rpx; height: 128rpx; border-radius: 64rpx; border: 4rpx solid rgba(255,255,255,0.5); display: block; }
.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  border-radius: 12rpx;
  padding: 4rpx 8rpx;
}
.user-info { flex: 1; }
.nickname { display: block; font-size: 34rpx; font-weight: 800; color: #fff; margin-bottom: 6rpx; }
.user-account { display: block; font-size: 22rpx; color: rgba(255,255,255,0.75); margin-bottom: 4rpx; }
.beast-id { display: block; font-size: 22rpx; color: rgba(255,255,255,0.75); }
.setting-btn { padding: 16rpx; }
.setting-icon { font-size: 40rpx; }

.gem-card {
  background: #fff;
  margin: -24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91,110,245,0.12);
}
.gem-card-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.gem-card-emoji { width: 64rpx; height: 64rpx; flex-shrink: 0; }
.gem-card-info { flex: 1; min-width: 0; }
.gem-card-label { display: block; font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.gem-card-num { display: block; font-size: 48rpx; font-weight: 900; color: #8B5CF6; }
.gem-bind-tip { display: block; margin-top: 8rpx; font-size: 20rpx; line-height: 1.5; }
.gem-bind-ok { color: #4F46E5; }
.gem-bind-pending { color: #D97706; }
.gem-card-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.gem-action-btn {
  min-width: 98rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.gem-recharge-btn { background: linear-gradient(135deg,#5B6EF5,#8B5CF6); color: #fff; }
.gem-transfer-btn { background: #F3F4F6; color: #374151; }
.gem-card-arrow { font-size: 36rpx; color: #ccc; }

.stats-row {
  display: flex;
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.stat-num { font-size: 40rpx; font-weight: 800; color: #333; }
.stat-num.success { color: #4CAF50; }
.stat-num.primary { color: #5B6EF5; }
.stat-num.gem { color: #8B5CF6; }
.stat-label { font-size: 20rpx; color: #999; display: flex; align-items: center; justify-content: center; gap: 4rpx; }
.gem-stat-icon { width: 22rpx; height: 22rpx; }
.stat-divider { width: 2rpx; background: #f0f0f0; }

.menu-group { margin: 20rpx 24rpx 0; }
.menu-group-title { font-size: 22rpx; color: #bbb; font-weight: 600; padding: 0 4rpx 12rpx; }
.menu-list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mi-blue { background: #EEF0FF; }
.mi-purple { background: #F5EEFF; }
.mi-green { background: #ECFDF5; }
.mi-orange { background: #FFF7ED; }
.mi-gold { background: #FFF7E6; }
.mi-red { background: #FFF1F2; }
.mi-teal { background: #E6FFFB; }
.mi-gray { background: #F5F6FA; }
.menu-icon { font-size: 36rpx; }
.menu-icon-img { width: 40rpx; height: 40rpx; }
.menu-text { font-size: 28rpx; font-weight: 600; color: #222; flex: 1; }
.menu-desc { font-size: 20rpx; color: #bbb; margin-right: 8rpx; }
.menu-arrow { font-size: 32rpx; color: #ccc; flex-shrink: 0; }
.menu-badge { background: #EF4444; color: #fff; border-radius: 20rpx; min-width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center; font-size: 20rpx; font-weight: 700; padding: 0 8rpx; margin-right: 8rpx; }

.logout-btn {
  margin: 32rpx 24rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 44rpx;
  color: #EF4444;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.version-text { display: block; text-align: center; font-size: 22rpx; color: #ccc; padding: 20rpx 0 0; }

/* 兼容性兜底：避免 gap 在部分微信基础库失效 */
.user-info {
  min-width: 0;
  margin-left: 24rpx;
}

.gem-card-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.gem-card-info {
  margin-left: 16rpx;
}

.gem-card-right {
  margin-left: 20rpx;
}

.gem-action-btn + .gem-action-btn {
  margin-left: 12rpx;
}

.gem-card-arrow {
  margin-left: 12rpx;
}

.stat-label {
  margin-top: 6rpx;
}


.stat-label image {
  margin-left: 4rpx;
}

.menu-icon-wrap {
  margin-right: 16rpx;
}

.menu-text {
  min-width: 0;
}

.menu-desc {
  margin-left: 12rpx;
}

