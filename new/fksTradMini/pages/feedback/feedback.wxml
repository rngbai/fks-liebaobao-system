<view class="container">
  <view class="hero-card">
    <view>
      <text class="hero-title">问题反馈</text>
      <text class="hero-sub">你的每条建议和 Bug 反馈，我们都会认真处理。</text>
    </view>
    <view class="hero-meta">
      <view class="meta-pill">今日已提交 {{feedbackMeta.todayCount}} / {{feedbackMeta.dailyLimit}}</view>
      <view class="meta-pill meta-pill--light">剩余 {{feedbackMeta.remainingCount}} 次</view>
    </view>
  </view>

  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'is-active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      {{item.label}}
    </view>
  </view>

  <view class="tips-card">
    <text class="tips-text">为避免恶意刷屏，单个用户每天最多可提交 {{feedbackMeta.dailyLimit}} 次反馈。</text>
  </view>

  <view class="list-wrap" wx:if="{{list.length}}">
    <view class="feedback-card" wx:for="{{list}}" wx:key="id">
      <view class="card-top">
        <view class="top-left">
          <text class="type-badge type-{{item.type === 'Bug' ? 'bug' : 'suggest'}}">{{item.type}}</text>
          <text class="mine-tag" wx:if="{{activeTab === 'all' && item.isMine}}">我的</text>
        </view>
        <text class="status-text status-{{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="card-title">{{item.title}}</view>
      <view class="card-content">{{item.content}}</view>

      <view class="reply-box" wx:if="{{item.adminReply}}">
        <text class="reply-label">处理说明</text>
        <text class="reply-text">{{item.adminReply}}</text>
      </view>

      <view class="card-bottom">
        <text class="card-time">{{item.time}}</text>
        <text class="card-handle" wx:if="{{item.handledTime}}">{{item.handledTime}}</text>
      </view>
    </view>
  </view>

  <view class="empty-wrap" wx:elif="{{!loading}}">
    <text class="empty-icon">💬</text>
    <text class="empty-title">{{activeTab === 'mine' ? '你还没有提交过反馈' : '暂时还没有反馈内容'}}</text>
    <text class="empty-sub">点击右下角按钮，告诉我们你遇到的问题或建议。</text>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">反馈加载中...</text>
  </view>

  <view class="fab" bindtap="openComposer">+</view>

  <view class="composer-mask" wx:if="{{showComposer}}" bindtap="closeComposer">
    <view class="composer-sheet" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">提交反馈</text>
        <text class="sheet-close" bindtap="closeComposer">✕</text>
      </view>

      <view class="sheet-card">
        <view class="form-item">
          <text class="label">反馈类型</text>
          <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeOptions}}">
            <view class="picker-row">
              <text class="picker-value">{{typeOptions[typeIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item vertical">
          <text class="label">反馈标题</text>
          <input
            class="text-input"
            placeholder="例如：技能数据不对 / 增加某个功能"
            value="{{title}}"
            maxlength="40"
            bindinput="onTitleInput"
            placeholder-style="color:#b7bfd8"
          />
        </view>

        <view class="form-item vertical">
          <text class="label">详细描述</text>
          <textarea
            class="text-area"
            placeholder="请尽量写清楚问题现象、出现位置、希望如何优化..."
            value="{{desc}}"
            maxlength="500"
            bindinput="onDescInput"
            placeholder-style="color:#b7bfd8"
          />
          <text class="word-count">{{desc.length}} / 500</text>
        </view>

        <view class="form-item vertical">
          <text class="label">联系方式（可选）</text>
          <input
            class="text-input"
            placeholder="QQ / 微信 / 手机号，方便我们联系你"
            value="{{contact}}"
            maxlength="32"
            bindinput="onContactInput"
            placeholder-style="color:#b7bfd8"
          />
        </view>
      </view>

      <view class="sheet-actions">
        <view class="sheet-btn sheet-btn--ghost" bindtap="closeComposer">取消</view>
        <view class="sheet-btn sheet-btn--primary {{submitting ? 'is-disabled' : ''}}" bindtap="submitFeedback">
          {{submitting ? '提交中...' : '确认提交'}}
        </view>
      </view>
    </view>
  </view>
</view>
