.container {
  padding: 0 0 120rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

/* 状态横幅 */
.status-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 32rpx;
}
.status-banner-0 { background: linear-gradient(135deg, #FF9800, #FFB74D); }
.status-banner-1 { background: linear-gradient(135deg, #5B6EF5, #7B8FF5); }
.status-banner-2 { background: linear-gradient(135deg, #4CAF50, #66BB6A); }
.status-banner-3 { background: linear-gradient(135deg, #FF5252, #FF7070); }

.status-icon { font-size: 60rpx; }
.status-info { display: flex; flex-direction: column; gap: 4rpx; }
.status-title { font-size: 34rpx; font-weight: 800; color: #fff; }
.status-desc { font-size: 24rpx; color: rgba(255,255,255,0.85); }

/* 步骤条 */
.step-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 40rpx;
  margin-bottom: 16rpx;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ddd;
}
.step-item.done .step-dot { background: #5B6EF5; }
.step-label { font-size: 22rpx; color: #999; white-space: nowrap; }
.step-item.done .step-label { color: #5B6EF5; font-weight: 600; }
.step-line {
  flex: 1;
  height: 4rpx;
  background: #ddd;
  margin: 0 8rpx;
  margin-bottom: 28rpx;
}
.step-line.line-done { background: #5B6EF5; }

/* 通用卡片 */
.info-card, .gem-card, .action-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #fafafa;
}
.info-row:last-child { border-bottom: none; }
.info-key { font-size: 26rpx; color: #999; }
.info-val-wrap { display: flex; align-items: center; gap: 12rpx; }
.info-val { font-size: 26rpx; color: #333; font-weight: 500; }
.info-val.mono { font-family: monospace; font-size: 24rpx; }
.info-val.gray { color: #bbb; }
.copy-btn {
  font-size: 22rpx;
  color: #5B6EF5;
  background: #F0F1FF;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 宝石明细 */
.gem-row {
  display: flex;
  align-items: center;
}
.gem-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.gem-label { font-size: 22rpx; color: #999; }
.gem-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #5B6EF5;
}
.gem-val.fee { color: #FF9800; }
.gem-val.total { color: #8B5CF6; font-size: 48rpx; }
.gem-divider { width: 2rpx; height: 60rpx; background: #f0f0f0; }

/* 截图 */
.screenshot {
  width: 100%;
  border-radius: 12rpx;
}

/* 操作区 */
.action-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}
.action-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.form-item { margin-bottom: 20rpx; }
.form-input {
  width: 100%;
  height: 80rpx;
  background: #F8F9FF;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #EAECFF;
}

.action-btn {
  background: linear-gradient(135deg, #5B6EF5, #8B5CF6);
  color: #fff;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 8rpx;
}
.confirm-btn { background: linear-gradient(135deg, #4CAF50, #66BB6A); }

.btn-appeal {
  text-align: center;
  color: #FF5252;
  font-size: 26rpx;
  padding: 20rpx 0 4rpx;
  border-top: 1rpx solid #fafafa;
  margin-top: 16rpx;
}

/* 完成/申诉状态 */
.done-card, .appeal-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 24rpx;
  margin: 0 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.done-icon, .appeal-icon { font-size: 80rpx; }
.done-text { font-size: 30rpx; font-weight: 600; color: #4CAF50; }
.appeal-text { font-size: 30rpx; font-weight: 600; color: #FF5252; }
.appeal-sub { font-size: 24rpx; color: #999; }
