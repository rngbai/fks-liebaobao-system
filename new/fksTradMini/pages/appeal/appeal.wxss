.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.alert-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #FFE082;
}
.alert-icon { font-size: 32rpx; flex-shrink: 0; }
.alert-text { font-size: 24rpx; color: #F57C00; line-height: 1.6; }

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.form-item { margin-bottom: 28rpx; }
.form-label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.form-label.required::before { content: '* '; color: #FF5252; }

.readonly-input {
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  font-family: monospace;
}

/* 原因选择 */
.reason-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.reason-item {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: #F5F6FA;
  border: 2rpx solid transparent;
}
.reason-item.selected {
  background: #F0F1FF;
  color: #5B6EF5;
  border-color: #5B6EF5;
  font-weight: 600;
}

/* 文本框 */
.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F8F9FF;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  border: 2rpx solid #EAECFF;
  line-height: 1.6;
}
.word-count { font-size: 22rpx; color: #bbb; text-align: right; display: block; margin-top: 8rpx; }

/* 图片上传 */
.upload-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 8rpx; }
.upload-thumb { position: relative; width: 160rpx; height: 160rpx; }
.thumb-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.del-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #FF5252;
  color: #fff;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #CACEFF;
  border-radius: 12rpx;
  background: #F8F9FF;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-icon { font-size: 60rpx; color: #5B6EF5; }
.upload-tip { font-size: 22rpx; color: #bbb; }

/* 提交 */
.submit-wrap {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
}
.submit-btn.active { background: linear-gradient(135deg, #FF5252, #FF7070); color: #fff; }
.submit-btn.disabled { background: #e0e0e0; color: #bbb; }
