.container {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: 60rpx;
}

.gem-balance-card {
  background: linear-gradient(135deg, #5B6EF5, #8B5CF6);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gem-balance-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
}

.gem-balance-num-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.gem-emoji {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.gem-balance-num {
  font-size: 60rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.gem-balance-tip {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.5;
}

.gem-recharge-btn {
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.58);
  color: #fff;
  border-radius: 40rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.func-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: #fff;
  padding: 32rpx 16rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.func-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.func-bg-1 { background: linear-gradient(135deg,#5B6EF5,#8B5CF6); }
.func-bg-2 { background: linear-gradient(135deg,#10B981,#059669); }
.func-bg-3 { background: linear-gradient(135deg,#F5A623,#F97316); }
.func-bg-4 { background: linear-gradient(135deg,#EF4444,#DC2626); }

.func-icon { font-size: 44rpx; }
.func-name { font-size: 24rpx; font-weight: 600; color: #222; }
.func-desc { font-size: 20rpx; color: #A1A1AA; text-align: center; line-height: 1.4; }

.query-card,
.rule-card,
.guarantee-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(91,110,245,0.08);
}

.query-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx 24rpx;
}

.query-title { font-size: 28rpx; font-weight: 700; color: #222; margin-bottom: 8rpx; }
.query-tip { font-size: 22rpx; color: #A1A1AA; margin-bottom: 20rpx; line-height: 1.6; }

.query-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.query-input {
  flex: 1;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #333;
  height: 80rpx;
}

.query-btn,
.btn-primary {
  background: linear-gradient(135deg, #5B6EF5, #8B5CF6);
  color: #fff;
  border-radius: 14rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.my-guarantee-section { margin: 20rpx 24rpx 0; }

.section-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.sec-title { font-size: 30rpx; font-weight: 700; color: #222; }
.sec-more { font-size: 24rpx; color: #5B6EF5; }

.guarantee-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #5B6EF5;
}

.gcard-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.gcard-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.gcard-id {
  font-size: 22rpx;
  color: #94A3B8;
  font-family: monospace;
  word-break: break-all;
}

.status-tag {
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-0 { background: #FFF3E0; color: #FF9800; }
.status-1 { background: #E0F2FE; color: #0284C7; }
.status-2 { background: #E8F5E9; color: #2E7D32; }
.status-3 { background: #FEE2E2; color: #DC2626; }

.gcard-gem {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.gcard-gem-icon {
  width: 32rpx;
  height: 32rpx;
}

.gcard-gem-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #8B5CF6;
}

.gcard-body {
  display: grid;
  gap: 10rpx;
}

.gcard-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.gcard-key {
  font-size: 24rpx;
  color: #94A3B8;
}

.gcard-val {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  word-break: break-word;
}

.gcard-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.6;
}

.gcard-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #A1A1AA;
}

.empty-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 70rpx 0;
  gap: 16rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text { color: #A1A1AA; font-size: 26rpx; }
.empty-btn { padding: 0 60rpx; margin-top: 8rpx; }

.rule-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx 24rpx;
}

.rule-title { font-size: 28rpx; font-weight: 700; color: #222; margin-bottom: 20rpx; }
.rule-item { display: flex; gap: 8rpx; margin-bottom: 14rpx; align-items: flex-start; }
.rule-dot { color: #5B6EF5; font-weight: 700; flex-shrink: 0; margin-top: 2rpx; }
.rule-text { font-size: 24rpx; color: #666; line-height: 1.7; }
.rule-highlight { color: #EF4444; font-weight: 700; }

/* 兼容性兜底：避免 grid / gap 在部分微信基础库失效 */
.gem-balance-num-row image {
  margin-right: 8rpx;
}

.func-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 32rpx 8rpx 16rpx;
  box-sizing: border-box;
}

.func-item {
  width: 25%;
  padding: 0 8rpx 16rpx;
  box-sizing: border-box;
}

.func-name {
  display: block;
  margin-top: 4rpx;
}

.func-desc {
  margin-top: 6rpx;
}

.query-input-row {
  display: flex;
  align-items: center;
}

.query-btn,
.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.query-btn {
  min-width: 120rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.gcard-left .status-tag {
  margin-top: 8rpx;
}

.gcard-gem-num {
  margin-left: 8rpx;
}

.gcard-body {
  display: block;
}

.gcard-row + .gcard-row {
  margin-top: 10rpx;
}

.gcard-key {
  width: 140rpx;
  flex-shrink: 0;
}

.empty-view .empty-text,
.empty-view .empty-btn {
  margin-top: 16rpx;
}


.rule-text {
  margin-left: 8rpx;
}

.public-orders-section {
  margin-top: 24rpx;
}

.public-filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.filter-active {
  background: #5B6EF5;
  color: #fff;
}

.public-card {
  border-left: 6rpx solid #5B6EF5;
}

.status-open {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.gcard-val-highlight {
  color: #059669;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #94a3b8;
}

