/* 社区名流页：仅顶部导航 + 主分类 Tab 条深色；其余保持浅底原样 */
page {
  background: #F0F2FA;
}

.page {
  min-height: 100vh;
  background: #F0F2FA;
  padding-bottom: 40rpx;
}

.subnav-shell {
  margin: 16rpx 24rpx 0;
  min-height: 112rpx;
}

.subnav-shell--captain {
  min-height: 208rpx;
}

/* 主分类 Tab（与导航栏衔接的深色条 + 选中金胶囊） */
.cat-scroll {
  width: 100%;
  margin-top: 0;
  background: #121212;
  white-space: nowrap;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}
.cat-tabs {
  display: inline-flex;
  padding: 10rpx 12rpx 14rpx;
  align-items: center;
}
.cat-tab {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 14rpx 22rpx;
  margin: 0 4rpx;
  position: relative;
  transition: all 0.2s;
  border-radius: 999rpx;
}
.cat-tab-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  white-space: nowrap;
  font-weight: 500;
}
.cat-tab--active {
  background: linear-gradient(180deg, #f3e2a5, #d4b871);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.35);
}
.cat-tab--active .cat-tab-label {
  color: #1a140c;
  font-weight: 800;
}
.cat-tab--active::after {
  display: none;
}

/* 子分类 Tab（非大咖团队长时） */
.sub-scroll-wrap {
  min-height: 112rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid #eceef8;
  box-sizing: border-box;
}

.sub-scroll {
  background: transparent;
  white-space: nowrap;
}
.sub-tabs { display: inline-flex; gap: 16rpx; }
.sub-tab {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  background: #F0F2FA;
  white-space: nowrap;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.sub-tab--active {
  color: #5B6EF5;
  background: #EEF0FF;
  border-color: #5B6EF5;
  font-weight: 700;
}

/* 大咖团队长 · 横向游戏入口（参考设计稿） */
.game-dock-card {
  padding: 20rpx 20rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid #eceef8;
}

.game-dock-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 16rpx;
}

.game-dock-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1f2740;
}

.game-dock-arrow {
  font-size: 36rpx;
  color: #c5cad8;
  font-weight: 300;
  line-height: 1;
}

.game-dock-scroll {
  width: 100%;
  white-space: nowrap;
}

.game-dock-row {
  display: inline-flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 4rpx 0;
}

.game-dock-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 128rpx;
  flex-shrink: 0;
}

.game-dock-thumb-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f6f7fb 0%, #eef1f8 100%);
  border: 2rpx solid #e4e8f2;
  box-sizing: border-box;
  overflow: hidden;
}

.game-dock-item--active .game-dock-thumb-wrap {
  border-color: #5b6ef5;
  box-shadow: 0 0 0 3rpx rgba(91, 110, 245, 0.2);
}

.game-dock-thumb {
  width: 100%;
  height: 100%;
}

.game-dock-name {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #5f6881;
  text-align: center;
  line-height: 1.25;
  white-space: normal;
}

.game-dock-item--active .game-dock-name {
  color: #5b6ef5;
  font-weight: 700;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 32rpx; font-weight: 700; color: #333; }
.empty-desc { font-size: 26rpx; color: #999; }
.empty-state--error .empty-title { color: #7c2d12; }
.empty-state--error .empty-desc { color: #b45309; max-width: 560rpx; text-align: center; line-height: 1.7; }
.empty-action {
  margin-top: 10rpx;
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5B6EF5, #7B8EFF);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(91, 110, 245, 0.18);
}

.list-loading-mask {
  margin: 20rpx 24rpx 0;
  padding: 14rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(91, 110, 245, 0.12);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(10rpx);
}

.list-loading-text {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
}

/* 卡片列表 */
.card-list {
  padding: 24rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91,110,245,0.08);
  position: relative;
}

/* 顶部彩色勋章条 */
.card-ribbon {
  height: 6rpx;
}
.card-ribbon.gold { background: linear-gradient(90deg, #FFD700, #FFA500); }
.card-ribbon.silver { background: linear-gradient(90deg, #C0C0C0, #A8A8A8); }
.card-ribbon.verified { background: linear-gradient(90deg, #5B6EF5, #7B8EFF); }
.card-ribbon.streamer { background: linear-gradient(90deg, #FF6B9D, #FF8E53); }
.card-ribbon.guild { background: linear-gradient(90deg, #00C896, #00A878); }

.card-body {
  display: flex;
  padding: 24rpx;
  gap: 24rpx;
  align-items: flex-start;
}

/* 头像 */
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #EEF0FF;
}
.badge-icon {
  position: absolute;
  bottom: -6rpx; right: -6rpx;
  width: 44rpx; height: 44rpx;
  border-radius: 22rpx;
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
}
.badge-icon.gold { background: linear-gradient(135deg, #FFD700, #FFA500); }
.badge-icon.silver { background: linear-gradient(135deg, #E8E8E8, #C0C0C0); }
.badge-icon.verified { background: linear-gradient(135deg, #5B6EF5, #7B8EFF); }
.badge-icon.streamer { background: linear-gradient(135deg, #FF6B9D, #FF8E53); }
.badge-icon.guild { background: linear-gradient(135deg, #00C896, #00A878); }

/* 信息区 */
.info-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.name-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A1A2E;
}
.badge-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
.badge-tag.gold { background: #FFF3CC; color: #B8860B; }
.badge-tag.silver { background: #F0F0F0; color: #707070; }
.badge-tag.verified { background: #EEF0FF; color: #5B6EF5; }
.badge-tag.streamer { background: #FFF0F5; color: #FF6B9D; }
.badge-tag.guild { background: #E8FFF7; color: #009966; }

.game-tag {
  font-size: 22rpx;
  color: #5B6EF5;
  background: #EEF0FF;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  align-self: flex-start;
}
.bio-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 联系按钮 */
.contact-row {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
  flex-wrap: wrap;
}
.contact-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.wechat-btn { background: #E8F8F0; }
.wechat-btn .contact-label { color: #07C160; }
.qq-btn { background: #E8F0FF; }
.qq-btn .contact-label { color: #1677FF; }
.contact-icon { font-size: 26rpx; }

.apply-panel {
  margin: 40rpx 24rpx 0;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(91,110,245,0.08);
}

.apply-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.apply-copy {
  flex: 1;
  min-width: 0;
}

.apply-title {
  display: block;
  color: #1f2740;
  font-size: 32rpx;
  font-weight: 800;
}

.apply-desc {
  display: block;
  margin-top: 12rpx;
  color: #7d86a0;
  font-size: 24rpx;
  line-height: 1.7;
}

.apply-btn {
  padding: 0 28rpx;
  min-width: 160rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5B6EF5, #7B8EFF);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.apply-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.apply-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #EEF1FF;
  color: #5B6EF5;
  font-size: 22rpx;
  font-weight: 600;
}

.bottom-safe { height: 60rpx; }
