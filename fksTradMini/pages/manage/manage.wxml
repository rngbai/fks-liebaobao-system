<view class="page">
  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-kicker">MANAGE CENTER</text>
      <text class="hero-title">担保管理台</text>
      <text class="hero-desc">集中看待用户转出申请、转入记录和近 7 天流水。</text>

    </view>
    <view class="hero-chip">待处理 {{totals.pendingActionCount}}</view>
  </view>

  <view class="summary-grid">
    <view class="summary-card">
      <text class="summary-label">累计转入</text>
      <text class="summary-value">{{totals.totalRechargeAmount}}</text>
      <text class="summary-sub">{{totals.totalRechargeCount}} 笔</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">已完成担保</text>
      <text class="summary-value">{{totals.completedGuaranteeCount}}</text>
      <text class="summary-sub">总用户 {{totals.userCount}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">钱包可用</text>
      <text class="summary-value">{{totals.walletBalance}}</text>
      <text class="summary-sub">锁定 {{totals.lockedGems}}</text>
    </view>
    <view class="summary-card summary-card-highlight">
      <text class="summary-label">待处理</text>
      <text class="summary-value">{{totals.pendingActionCount}}</text>
      <text class="summary-sub">用户转出 {{totals.pendingWithdrawCount}}</text>

    </view>
  </view>

  <view class="section-card today-card">
    <view class="section-head">
      <view>
        <text class="section-kicker">TODAY</text>
        <text class="section-title">今日流水概览</text>
      </view>
    </view>
    <view class="today-grid">
      <view class="today-item">
        <text class="today-num">{{today.rechargeAmount}}</text>
        <text class="today-label">今日转入宝石</text>
        <text class="today-sub">{{today.rechargeCount}} 笔</text>
      </view>
      <view class="today-item today-item-warm">
        <text class="today-num">{{today.transferAmount}}</text>
        <text class="today-label">今日转出宝石</text>
        <text class="today-sub">{{today.transferCount}} 单</text>
      </view>
      <view class="today-item">
        <text class="today-num">{{today.platformFeeAmount}}</text>
        <text class="today-label">今日手续费</text>
        <text class="today-sub">担保 {{today.guaranteeFeeAmount}} / 转出 {{today.withdrawFeeAmount}}</text>
      </view>
    </view>

  </view>



  <view class="section-card">
    <view class="section-head">
      <view>
        <text class="section-kicker">PENDING USER TRANSFER</text>
        <text class="section-title">用户转出申请</text>
      </view>
      <text class="section-tip">用户在宝石页提交后会出现在这里</text>
    </view>
    <view class="empty-block" wx:if="{{pendingWithdrawList.length === 0}}">
      <text class="empty-text">当前没有待处理的用户转出申请</text>
    </view>
    <view class="transfer-list" wx:else>
      <view class="transfer-card" wx:for="{{pendingWithdrawList}}" wx:key="id">
        <view class="transfer-top">
          <view>
            <text class="order-no">{{item.id}}</text>
            <text class="transfer-status">{{item.statusText}}</text>
          </view>
          <view class="transfer-amount-block">
            <text class="transfer-amount">{{item.actualAmount}}</text>
            <text class="transfer-amount-label">预计实转</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-key">申请人</text>
          <text class="info-val">{{item.userNickName || '方块兽玩家'}} / {{item.account || '未设置账号'}}</text>
        </view>
        <view class="info-row">
          <text class="info-key">绑定ID</text>
          <view class="info-actions">
            <text class="info-val">{{item.beastNick || item.userNickName || '未设置'}} / {{item.beastId || '未绑定'}}</text>
            <text class="copy-btn" bindtap="copyText" data-text="{{item.beastId}}" data-label="方块兽ID">复制ID</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-key">申请数量</text>
          <text class="info-val">{{item.requestAmount}}（手续费 {{item.feeAmount}}）</text>
        </view>
        <view class="info-row" wx:if="{{item.userNote}}">
          <text class="info-key">用户备注</text>
          <text class="info-val info-val-wrap">{{item.userNote}}</text>
        </view>
        <view class="info-row">
          <text class="info-key">申请时间</text>
          <text class="info-val">{{item.createTime}}</text>
        </view>
        <view class="transfer-actions">
          <view class="ghost-btn" bindtap="copyText" data-text="{{item.id}}" data-label="申请单号">复制单号</view>
          <view class="primary-btn" bindtap="completeWithdraw" data-id="{{item.id}}">已处理用户转出</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <text class="section-kicker">DAILY FLOW</text>
        <text class="section-title">近 7 天流水</text>
      </view>
    </view>
    <view class="daily-list">
      <view class="daily-item" wx:for="{{dailyFlow}}" wx:key="date">
        <view class="daily-date">{{item.date}}</view>
        <view class="daily-stats">
          <text class="daily-stat">转入 {{item.rechargeAmount}} / {{item.rechargeCount}} 笔</text>
          <text class="daily-stat">转出 {{item.transferAmount}} / {{item.transferCount}} 单</text>
          <text class="daily-stat">新担保 {{item.guaranteeCreatedCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <text class="section-kicker">TRANSFER IN LIST</text>
        <text class="section-title">用户转入列表</text>
      </view>
    </view>
    <view class="empty-block" wx:if="{{rechargeList.length === 0}}">
      <text class="empty-text">暂无转入记录</text>
    </view>
    <view class="recharge-list" wx:else>
      <view class="recharge-item" wx:for="{{rechargeList}}" wx:key="id">
        <view class="recharge-top">
          <view>
            <text class="recharge-user">{{item.userNickName || '方块兽玩家'}}</text>
            <text class="recharge-meta">{{item.account || '未设置账号'}} · {{item.beastId || '未绑定ID'}}</text>
          </view>
          <view class="recharge-right">
            <text class="recharge-amount">+{{item.amount}}</text>
            <text class="recharge-status recharge-status-{{item.statusClass}}">{{item.statusText}}</text>
          </view>
        </view>
        <view class="recharge-bottom">
          <text class="recharge-time">{{item.time}}</text>
          <text class="recharge-code" wx:if="{{item.verifyCode}}">校验码 {{item.verifyCode}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <text class="section-kicker">GUARANTEE RECORDS</text>
        <text class="section-title">担保记录</text>
      </view>
    </view>
    <view class="empty-block" wx:if="{{guaranteeList.length === 0}}">
      <text class="empty-text">暂无担保记录</text>
    </view>
    <view class="guarantee-list" wx:else>
      <view class="guarantee-item" wx:for="{{guaranteeList}}" wx:key="id">
        <view class="guarantee-top">
          <text class="order-no">{{item.id}}</text>
          <text class="guarantee-badge guarantee-badge-{{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="info-row">
          <text class="info-key">卖家ID</text>
          <text class="info-val">{{item.sellerBeastId || '未绑定'}}</text>
        </view>
        <view class="info-row" wx:if="{{item.buyerBeastId}}">
          <text class="info-key">买家资料</text>
          <text class="info-val">{{item.buyerBeastNick || '未填写'}} / {{item.buyerBeastId}}</text>
        </view>
        <view class="info-row">
          <text class="info-key">担保宝石</text>
          <text class="info-val">{{item.gemAmount}}（手续费 {{item.feeAmount}} / 实转 {{item.actualReceive}}）</text>
        </view>

        <view class="info-row" wx:if="{{item.remark}}">
          <text class="info-key">说明</text>
          <text class="info-val info-val-wrap">{{item.remark}}</text>
        </view>
        <view class="info-row" wx:if="{{item.adminNote}}">
          <text class="info-key">后台备注</text>
          <text class="info-val info-val-wrap">{{item.adminNote}}</text>
        </view>
        <view class="guarantee-time-row">
          <text class="time-chip">创建 {{item.createTime}}</text>
          <text class="time-chip" wx:if="{{item.finishedTime}}">完成 {{item.finishedTime}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
