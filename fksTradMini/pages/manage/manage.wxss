.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #eef2ff 0%, #f6f8ff 22%, #f5f6fa 100%);
}

.hero-card,
.section-card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(82, 104, 184, 0.08);
}

.hero-card {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #18224f 0%, #3b4fd5 56%, #47c9ff 100%);
  color: #ffffff;
}

.hero-kicker,
.section-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.68);
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.82);
}

.hero-chip {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  font-weight: 700;
}

.summary-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(82, 104, 184, 0.06);
}

.summary-card-highlight {
  background: linear-gradient(135deg, #fff7ed, #fff1db);
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #8a92a8;
}

.summary-value {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 800;
  color: #1d2640;
}

.summary-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #66708b;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.section-kicker {
  color: #9aa3bf;
}

.section-title {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #1b2340;
}

.section-tip {
  font-size: 22rpx;
  color: #7180af;
}

.today-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.today-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #eef2ff, #f6f8ff);
}

.today-item-warm {
  background: linear-gradient(135deg, #fff7ed, #fff1db);
}

.today-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #202742;
}

.today-label {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #59627d;
}

.today-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #94a0be;
}

.empty-block {
  padding: 40rpx 0 18rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: #a0a9bf;
}

.transfer-list,
.recharge-list,
.guarantee-list,
.daily-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.transfer-card,
.recharge-item,
.guarantee-item,
.daily-item {
  border-radius: 22rpx;
  background: #f8faff;
  border: 1rpx solid #ecf0fb;
}

.transfer-card,
.recharge-item,
.guarantee-item {
  padding: 22rpx;
}

.transfer-top,
.recharge-top,
.guarantee-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.order-no {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #3d51d1;
  word-break: break-all;
}

.transfer-status,
.guarantee-badge {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.transfer-status,
.guarantee-badge-pending {
  background: #fff4e8;
  color: #d97706;
}

.guarantee-badge-matched {
  background: #eef2ff;
  color: #4f46e5;
}

.guarantee-badge-done {
  background: #eafbf3;
  color: #16a34a;
}

.guarantee-badge-appeal {
  background: #fef2f2;
  color: #ef4444;
}

.transfer-amount-block,
.recharge-right {
  text-align: right;
}

.transfer-amount,
.recharge-amount {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
}

.transfer-amount-label {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8e99b4;
}

.info-row,
.recharge-bottom,
.guarantee-time-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.info-key,
.recharge-time,
.recharge-code,
.time-chip {
  font-size: 22rpx;
  color: #8d97b0;
}

.info-val {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #26314d;
}

.info-val-wrap {
  line-height: 1.6;
}

.info-actions {
  display: flex;
  flex: 1;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
}

.copy-btn,
.ghost-btn,
.primary-btn {
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.copy-btn,
.ghost-btn {
  padding: 10rpx 18rpx;
  background: #edf2ff;
  color: #4b63db;
}

.transfer-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.ghost-btn {
  flex: 1;
}

.primary-btn {
  flex: 2;
  padding: 12rpx 18rpx;
  background: linear-gradient(135deg, #4f46e5, #6d5dfc);
  color: #ffffff;
}

.daily-item {
  padding: 20rpx 22rpx;
}

.daily-date {
  font-size: 24rpx;
  font-weight: 700;
  color: #293452;
}

.daily-stats {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.daily-stat {
  font-size: 22rpx;
  color: #6c7690;
}

.recharge-user {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.recharge-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8d97b0;
}

.recharge-status {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.recharge-status-success {
  background: #eafbf3;
  color: #16a34a;
}

.recharge-status-pending {
  background: #fff4e8;
  color: #d97706;
}

.recharge-status-cancelled,
.recharge-status-expired {
  background: #f3f4f6;
  color: #6b7280;
}
