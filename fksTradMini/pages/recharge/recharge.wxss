.container {
  background: #F5F6FA;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.balance-bar {
  background: linear-gradient(135deg, #5B6EF5, #8B5CF6);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-inline-state {
  margin: 20rpx 24rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: linear-gradient(135deg, #fff7ed, #fffbeb);
  border: 1rpx solid rgba(217, 119, 6, 0.18);
  box-shadow: 0 12rpx 24rpx rgba(217, 119, 6, 0.08);
}

.page-inline-copy {
  flex: 1;
  min-width: 0;
}

.page-inline-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #9a3412;
}

.page-inline-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #b45309;
}

.page-inline-action {
  flex-shrink: 0;
  min-width: 148rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5B6EF5, #7c3aed);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.bal-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-bottom: 10rpx;
}

.bal-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.bal-gem {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.bal-num {
  font-size: 58rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.limit-box {
  min-width: 200rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
}

.limit-num {
  display: block;
  text-align: right;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.limit-tip {
  display: block;
  text-align: right;
  color: rgba(255, 255, 255, 0.75);
  font-size: 20rpx;
  margin-top: 6rpx;
}

.panel-card {
  background: #fff;
  margin: -24rpx 24rpx 0;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 32rpx;
  box-shadow: 0 16rpx 36rpx rgba(69, 83, 201, 0.08);
  position: relative;
}

.panel-head {
  margin-bottom: 28rpx;
}

.panel-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.panel-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #222;
}

.panel-link {
  color: #2C8BFF;
  font-size: 24rpx;
  font-weight: 600;
}

.panel-sub {
  display: block;
  font-size: 22rpx;
  color: #9AA0B1;
  line-height: 1.6;
}

.stepper-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.stepper-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stepper-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid #D9DCE8;
  color: #BBBFCB;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.stepper-active {
  background: linear-gradient(135deg, #2C8BFF, #5B6EF5);
  border-color: transparent;
  color: #fff;
}

.stepper-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #B0B4C3;
}

.stepper-text-active {
  color: #2F3B59;
  font-weight: 700;
}

.stepper-line {
  flex: 1;
  height: 2rpx;
  background: #E8ECF4;
  margin: 0 10rpx 28rpx;
}

.stepper-line-active {
  background: linear-gradient(90deg, #2C8BFF, #5B6EF5);
}

.form-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #222;
}

.form-tag {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: #EEF5FF;
  color: #2C8BFF;
  font-size: 22rpx;
  font-weight: 700;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 4rpx;
}

.input-with-unit {
  height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #F5F7FC;
  border: 2rpx solid transparent;
}

.input-with-unit:focus-within {
  border-color: #9BC7FF;
  background: #F9FBFF;
}

.form-input {
  flex: 1;
  height: 92rpx;
  font-size: 32rpx;
  color: #222;
}

.amount-tips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.amount-tip-item {
  min-width: 108rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  background: #EEF3FF;
  color: #4F67F6;
  font-size: 26rpx;
  font-weight: 700;
}

.biz-card {
  background: #F8FAFF;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid #E8EDFF;
  margin-bottom: 28rpx;
}

.biz-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #EEF1F7;
}

.biz-row-last {
  border-bottom: none;
}

.biz-key {
  font-size: 24rpx;
  color: #96A0B5;
}

.biz-val {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #2A3142;
  font-weight: 700;
}

.biz-val-light {
  color: #6B7280;
  font-weight: 500;
  line-height: 1.5;
}

.countdown-wrap {
  padding: 12rpx 0 28rpx;
  text-align: center;
}

.countdown-text {
  display: block;
  font-size: 76rpx;
  font-weight: 900;
  color: #1F2937;
  line-height: 1;
  margin-bottom: 12rpx;
}

.countdown-tip {
  display: block;
  font-size: 24rpx;
  color: #9AA0B1;
}

.order-card {
  background: #F7F9FD;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EBEFF7;
}

.order-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.order-id {
  display: block;
  margin: 14rpx 0 22rpx;
  font-size: 32rpx;
  color: #111827;
  font-weight: 800;
  font-family: monospace;
  word-break: break-all;
}

.order-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.info-cell {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
}

.info-cell-label {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.info-cell-val {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 700;
  line-height: 1.4;
}

.info-id {
  color: #2C8BFF;
}

.info-cell-val-row,
.info-cell-gem-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-btn-sm,
.copy-btn-inline {
  flex-shrink: 0;
  background: #E8F2FF;
  color: #2C8BFF;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 10rpx;
  padding: 8rpx 16rpx;
}

.verify-card {
  background: linear-gradient(180deg, #F1FBFF, #ECF8FF);
  border: 1rpx solid #CDEDFC;
  border-radius: 24rpx;
  padding: 24rpx;
}

.verify-title-row {
  margin-bottom: 20rpx;
}

.verify-title {
  display: block;
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 800;
  line-height: 1.4;
}

.verify-help {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6B7280;
}

.verify-input {
  width: 100%;
  height: 92rpx;
  background: #fff;
  border-radius: 18rpx;
  border: 2rpx solid #DDE5F2;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 10rpx;
  color: #2563EB;
  margin-bottom: 22rpx;
}

.demo-box {
  background: #FFF8E8;
  border: 1rpx dashed #F6C766;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  margin-top: 20rpx;
}

.demo-title {
  display: block;
  font-size: 24rpx;
  color: #D97706;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.demo-text {
  display: block;
  font-size: 22rpx;
  color: #8A5A12;
  line-height: 1.6;
}

.cancel-btn {
  margin-top: 30rpx;
  text-align: center;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.cancel-tip {
  display: block;
  text-align: center;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #9AA0B1;
}

.success-card {
  padding: 30rpx 8rpx 12rpx;
  text-align: center;
}

.success-icon {
  display: block;
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 18rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  color: #16A34A;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.success-amount-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.success-gem {
  width: 38rpx;
  height: 38rpx;
}

.success-amount {
  font-size: 44rpx;
  color: #1F2937;
  font-weight: 900;
}

.success-amount-unit {
  font-size: 28rpx;
  color: #4B5563;
  font-weight: 600;
}

.success-desc {
  display: block;
  font-size: 24rpx;
  color: #7C8AA5;
  margin-bottom: 10rpx;
}

.success-balance {
  font-size: 24rpx;
  color: #5B6EF5;
  font-weight: 700;
  margin-bottom: 28rpx;
}

.success-btn,
.success-btn2 {
  width: 100%;
  margin-top: 12rpx;
}

.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.record-section {
  margin: 24rpx 24rpx 0;
}

.section-title-bar {
  margin-bottom: 16rpx;
}

.sec-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
}

.record-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #F1F4F8;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
  min-width: 0;
}

.record-order-id {
  display: block;
  font-size: 24rpx;
  color: #2A3142;
  font-weight: 800;
  font-family: monospace;
  margin-bottom: 8rpx;
}

.record-desc {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.record-time {
  display: block;
  font-size: 22rpx;
  color: #A0AEC0;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.record-amount-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 800;
}

.amount-success {
  color: #16A34A;
}

.amount-cancelled,
.amount-expired {
  color: #4B5563;
}

.record-status {
  min-width: 106rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  border-radius: 23rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.record-status-success {
  background: #E9F9EF;
  color: #16A34A;
}

.record-status-cancelled {
  background: #FDECEC;
  color: #EF4444;
}

.record-status-expired {
  background: #F3F4F6;
  color: #6B7280;
}

.empty-view {
  padding: 50rpx 24rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #B0B7C7;
}

.verify-smart-tip {
  display: block;
  margin: 8rpx 0 16rpx;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(91, 110, 245, 0.06);
  font-size: 22rpx;
  color: #5B6EF5;
  line-height: 1.6;
}
