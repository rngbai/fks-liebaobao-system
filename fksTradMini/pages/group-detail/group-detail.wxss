.page {
  min-height: 100vh;
  padding: 26rpx 24rpx 52rpx;
  background: linear-gradient(180deg, #ecf5ff 0%, #f8fbff 36%, #f2f4ff 100%);
}

.hero-card,
.group-number-card,
.detail-card,
.safe-card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(75, 103, 167, 0.1);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #1b2150, #4257de 54%, #40d1ff 100%);
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.68);
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 1.18;
  color: #ffffff;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.74;
  color: rgba(255,255,255,0.82);
}

.group-number-card,
.detail-card,
.safe-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.group-number-label,
.detail-title,
.safe-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #16203d;
}

.group-number {
  display: block;
  margin-top: 18rpx;
  font-size: 54rpx;
  line-height: 1;
  letter-spacing: 4rpx;
  font-weight: 900;
  color: #3f50dc;
}

.group-number-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6f7895;
}

.primary-btn,
.ghost-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 29rpx;
  font-weight: 700;
}

.primary-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #4257de, #22c7f4);
  color: #ffffff;
}

.detail-item {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.detail-bullet {
  font-size: 26rpx;
  color: #4a5be0;
  line-height: 1.6;
}

.detail-text,
.safe-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.84;
  color: #56617f;
}

.footer-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ghost-btn {
  background: #ffffff;
  border: 1rpx solid #dfe5ff;
  color: #4257de;
}
