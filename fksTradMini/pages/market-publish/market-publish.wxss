.container { background: #F5F6FA; min-height: 100vh; padding-bottom: 60rpx; }
.type-toggle { display: flex; margin: 20rpx 24rpx 0; gap: 16rpx; }
.type-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 700; }
.type-sell-active { background: linear-gradient(135deg,#5B6EF5,#8B5CF6); color: #fff; }
.type-buy-active { background: linear-gradient(135deg,#10B981,#059669); color: #fff; }
.type-inactive { background: #fff; color: #999; }
.form-card { background: #fff; margin: 20rpx 24rpx 0; border-radius: 20rpx; padding: 28rpx 24rpx; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 12rpx; display: block; }
.form-label.required::before { content: '*'; color: #EF4444; margin-right: 4rpx; }
.optional { font-size: 22rpx; color: #bbb; font-weight: 400; }
.form-input { background: #F5F6FA; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: #333; height: 88rpx; display: block; width: 100%; box-sizing: border-box; }
.input-with-unit { display: flex; align-items: center; background: #F5F6FA; border-radius: 12rpx; padding: 0 20rpx; height: 88rpx; }
.input-with-unit .form-input { flex: 1; background: transparent; padding: 0; }
.unit-text { font-size: 26rpx; color: #8B5CF6; font-weight: 700; }
.textarea-input { background: #F5F6FA; border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #333; width: 100%; min-height: 100rpx; box-sizing: border-box; }
.limit-tip { font-size: 22rpx; color: #FF9800; padding: 12rpx 24rpx; background: #FFF9E6; margin: 16rpx 24rpx 0; border-radius: 12rpx; }
.submit-wrap { padding: 24rpx 24rpx 0; }
.submit-btn { height: 90rpx; line-height: 90rpx; border-radius: 45rpx; font-size: 30rpx; font-weight: 700; text-align: center; }

/* 兼容性兜底：避免 gap 在部分微信基础库失效 */
.type-btn + .type-btn {
  margin-left: 16rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

