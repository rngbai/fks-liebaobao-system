# ============================================================
# 方块兽担保系统 —— 环境变量配置模板
# 复制此文件为 .env，填写真实值后再启动服务
# 生产服务器: cp .env.example .env && nano .env
# ============================================================

# ---------- 服务器监听 ----------
RECHARGE_VERIFY_HOST=0.0.0.0
RECHARGE_VERIFY_PORT=5000

# ---------- MySQL 数据库 ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=fks_user
MYSQL_PASSWORD=your_strong_db_password_here
MYSQL_DATABASE=fks_trade

# ---------- 后台管理账号 ----------
FKS_ADMIN_USERNAME=admin
FKS_ADMIN_PASSWORD=your_strong_admin_password_here
# 后台 session 有效时间（毫秒），默认 12 小时
FKS_ADMIN_SESSION_TTL_MS=43200000

# ---------- 游戏接口凭证（Token 过期需要重新获取） ----------
FKS_GAME_USER_ID=9100503
FKS_GAME_TOKEN=your_game_jwt_token_here

# ---------- 其他配置 ----------
# 上传图片显示给小程序端的接收器昵称
RECEIVER_BEAST_NICK=面板小助手
# 日志存放目录（默认 fksapi/logs/）
# FKS_LOG_DIR=/var/log/fks
